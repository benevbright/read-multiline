{
  "name": "read-multiline",
  "version": "0.1.0",
  "description": "Simple multi-line input reader for Node.js terminals",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "readline",
    "multiline",
    "input",
    "terminal",
    "cli",
    "stdin"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@xterm/headless": "^6.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
